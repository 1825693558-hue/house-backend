# ============================================================
# 房源管理系统 - 环境变量配置模板
# 使用方式：复制本文件为 .env，填入实际值
# 注意：.env 文件包含敏感信息，请勿提交到版本控制
# ============================================================

# ---------- 应用基础配置 ----------

# 项目名称（显示在 Swagger 文档标题中）
PROJECT_NAME=房源管理系统API

# 调试模式：true = 开启详细日志和自动重载，false = 生产模式
DEBUG=true

# 应用密钥：用于加密 session 等，生产环境务必替换为随机长字符串
SECRET_KEY=your-secret-key-change-this-in-production


# ---------- 数据库配置 ----------

# MySQL 连接地址
# 格式：mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/house_management?charset=utf8mb4


# ---------- JWT 认证配置 ----------

# JWT 签名密钥：用于签发和验证 Token，生产环境务必替换为随机长字符串
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# JWT 签名算法，通常保持 HS256 即可
JWT_ALGORITHM=HS256

# Token 有效期（天），默认 7 天
JWT_EXPIRE_DAYS=7


# ---------- AES 加密配置 ----------

# AES-256 加密密钥：用于加密密码锁密码
# 要求：必须为 32 字节（32 个字符）
# 生成方式：openssl rand -hex 16
AES_SECRET_KEY=0123456789abcdef0123456789abcdef


# ---------- CORS 跨域配置 ----------

# 允许跨域访问的来源地址，多个用逗号分隔
# 示例：小程序域名、管理后台域名
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080


# ---------- 登录限流配置 ----------

# 同一 IP 在指定时间窗口内最多尝试登录次数
LOGIN_RATE_LIMIT_MAX=10

# 登录限流时间窗口（秒），默认 300 秒 = 5 分钟
LOGIN_RATE_LIMIT_WINDOW=300